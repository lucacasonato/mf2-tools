fn number {
  operand ToNumber { value @ $num };
  options {
    select @ $select: "exact" | "plural" | "ordinal" = "plural";
    minimumFractionDigits: ToNumber { .. } | Unset;
    numberingSystem: ToString { .. };
  }
  returns BoxNumber { value: $num, select: $select };
}
