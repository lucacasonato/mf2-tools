type BoxNumber {
  value: NumberLike;
  select: "exact" | "plural" | "ordinal";

  impl ToString { value: .value };

  when BoxNumber { select: "exact", .. } impl Select { key: NumberLike };
  when BoxNumber { select: "plural", .. } impl Select { key: NumberLike | "zero" | "one" };
}
